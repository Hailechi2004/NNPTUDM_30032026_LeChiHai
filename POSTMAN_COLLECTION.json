      "name": "1. POST - Send Text Message",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "user-id",
            "value": "671a1234567890abcdef0001",
            "type": "text",
            "description": "Replace with your actual user ID"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"to\": \"671a1234567890abcdef0002\",\n  \"type\": \"text\",\n  \"content\": \"Xin chào, đây là tin nhắn từ User 1\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/messages",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "messages"]
        }
      },
      "response": []
